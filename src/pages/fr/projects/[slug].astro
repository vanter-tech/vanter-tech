---
import { getCollection } from 'astro:content';
import Layout from '../../../layouts/Layout.astro';
import ProjectDetails from '../../../components/ProjectDetails.astro';

export async function getStaticPaths() {

  const Allprojects = await getCollection('projects');

  const frProjects = Allprojects.filter(project => project.id.startsWith('fr/'));

  return frProjects.map(project => {{
    const cleanSlug = project.id.split('/')[1];
    return {
      params: { slug: cleanSlug },
      props: { project }
    }
  }});
}

const { project } = Astro.props;
---

<Layout lang="fr">
  <ProjectDetails project={project} lang="fr" />
</Layout>