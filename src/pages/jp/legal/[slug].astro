---
import LegalViewer from '../../../components/LegalViewer.astro';

export async function getStaticPaths() {
  return [
    { 
      params: { slug: 'terms' }, 
      props: { pdfUrl: '/files/vanter_placeholder_terms.pdf' } 
    },
    { 
      params: { slug: 'privacy' }, 
      props: { pdfUrl: '/files/vanter_placeholder_terms.pdf' } 
    },
    { 
      params: { slug: 'cookies' }, 
      props: { pdfUrl: '/files/vanter_placeholder_terms.pdf' } 
    }
  ];
}

const {slug} = Astro.params;
const { pdfUrl } = Astro.props;
---

<LegalViewer 
lang="jp" 
slug={slug as 'terms' | 'privacy' | 'cookies'} 
pdfUrl={pdfUrl} 
/>