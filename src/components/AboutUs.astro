---

import { useTranslation } from '../i18n/ui';

interface Props {
    lang: 'en' | 'es' | 'fr' | 'jp';
}

const { lang } = Astro.props;
const t = useTranslation(lang);

---


<section class="px-6 py-24 antialiased bg-vanter-bg">
  <div class="mx-auto max-w-6xl">
    
    <div class="mb-16">
      <h3 class="max-w-3xl text-4xl font-bold leading-tight tracking-tight text-balance text-white md:text-5xl lg:text-6xl">
        {t('h3.Tittle.AboutUs')}<br>
        <span class="bg-linear-to-r from-gray-200 to-gray-600 bg-clip-text text-transparent">{t('h3.span.Tittle.AboutUs')}</span>
      </h3>
    </div>

    <div class="grid grid-cols-1 gap-6 lg:grid-cols-2">
      
      <div class="relative flex flex-col overflow-hidden transition-colors duration-500 border group rounded-4xl border-white/10 bg-[#0a0a0a] p-8 md:p-10 hover:border-white/20">
        
        <div class="pointer-events-none absolute right-0 top-0 h-125 w-125 -translate-y-1/2 translate-x-1/3 rounded-full bg-white/5 blur-[120px] transition-opacity duration-500 group-hover:bg-white/10"></div>

        <div class="relative z-10 grow">
          <h4 class="mb-6 text-2xl font-bold text-white text-balance">
            {t('h4.FC.Tittle.AboutUs')}
          </h4>
          
          <div class="mb-12 space-y-6 text-base leading-relaxed text-pretty text-gray-400 md:text-lg">
            <p>
              {t('p.FC.AboutUs')}
            </p>
            <p>
              {t('p.FC.AboutUs.2')}
            </p>
            <p>
              {t('p.FC.AboutUs.3')}
            </p>
          </div>
        </div>

        <div class="relative z-10 mt-auto grid grid-cols-2 gap-6 border-t border-white/10 pt-8 sm:grid-cols-3">
          <div>
            <div class="mb-1 text-3xl font-bold text-white">+10k</div>
            <div class="text-[10px] font-semibold tracking-widest uppercase text-gray-500">{t('div.FC.subtittle.AboutUs')}</div>
          </div>
          <div>
            <div class="mb-1 text-3xl font-bold text-white">0%</div>
            <div class="text-[10px] font-semibold tracking-widest uppercase text-gray-500">{t('div.FC.subtittle.AboutUs.2')}</div>
          </div>
          <div class="hidden sm:block">
            <div class="mb-1 text-3xl font-bold text-white">100%</div>
            <div class="text-[10px] font-semibold tracking-widest uppercase text-gray-500">{t('div.FC.subtittle.AboutUs.3')}</div>
          </div>
        </div>
      </div>

      <div class="flex flex-col gap-6">
        
        <div class="relative flex flex-1 flex-col justify-between overflow-hidden transition-colors duration-500 border rounded-4xl border-white/10 bg-[#0a0a0a] p-8 hover:border-white/20">
          <div class="relative z-10 mb-8">
            <h4 class="mb-3 text-xl font-bold text-white text-balance">
              {t('h4.SC.Tittle.AboutUs')}
            </h4>
            <p class="text-sm leading-relaxed text-pretty text-gray-400 md:text-base">
              {t('p.SC.AboutUs')}
            </p>
          </div>
          
          <div class="relative z-10 mt-auto flex w-[120%] translate-x-4 translate-y-4 gap-4 rounded-xl border border-white/5 bg-white/3 p-4">
            <div class="w-1/3 space-y-3">
              <div class="h-4 rounded bg-white/10 animate-pulse"></div>
              <div class="h-2 w-3/4 rounded bg-white/5"></div>
              <div class="h-2 w-1/2 rounded bg-white/5"></div>
            </div>
            <div class="w-2/3 rounded-lg border border-white/10 bg-[#111] p-3 shadow-lg">
              <div class="mb-3 flex items-center gap-2">
                 <div class="rounded bg-blue-500/20 px-2 py-1 text-[9px] font-bold tracking-wider uppercase text-blue-400">DevOps</div>
                 <span class="text-xs font-medium text-white">Pipeline Activo</span>
              </div>
              <div class="h-1 overflow-hidden rounded-full bg-white/10">
                <div class="h-full w-3/4 bg-blue-500"></div>
              </div>
            </div>
          </div>
        </div>

        <div class="flex flex-1 flex-col justify-between transition-colors duration-500 border rounded-4xl border-white/10 bg-[#0a0a0a] p-8 hover:border-white/20">
          <div class="mb-8">
            <h4 class="mb-3 text-xl font-bold text-white text-balance">
                {t('h4.TC.Tittle.AboutUs')}
            </h4>
            <p class="text-sm leading-relaxed text-pretty text-gray-400 md:text-base">
              {t('p.TC.AboutUs')}
            </p>
          </div>

          <div class="mt-auto flex items-center justify-around rounded-2xl border border-white/5 bg-black p-6 shadow-inner">
            
            <div class="flex flex-col items-center">
              <div class="mb-2 flex h-14 w-14 items-center justify-center rounded-full border-4 border-emerald-500/30 border-t-emerald-500 shadow-[0_0_15px_rgba(16,185,129,0.2)]">
                <span class="text-sm font-bold text-white">99</span>
              </div>
              <span class="text-[10px] tracking-wider uppercase text-gray-500">{t('span.TC.subtittle.AboutUs')}</span>
            </div>

            <div class="flex flex-col items-center">
              <div class="mb-2 flex h-14 w-14 items-center justify-center rounded-full border-4 border-blue-500/30 border-t-blue-500 shadow-[0_0_15px_rgba(59,130,246,0.2)]">
                <span class="text-sm font-bold text-white">100</span>
              </div>
              <span class="text-[10px] tracking-wider uppercase text-gray-500">{t('span.TC.subtittle.AboutUs.2')}</span>
            </div>

            <div class="flex flex-col items-center">
              <div class="mb-2 flex h-14 w-14 items-center justify-center rounded-full border-4 border-purple-500/30 border-t-purple-500 shadow-[0_0_15px_rgba(168,85,247,0.2)]">
                <span class="text-sm font-bold text-white">100</span>
              </div>
              <span class="text-[10px] tracking-wider uppercase text-gray-500">SEO</span>
            </div>

          </div>
        </div>

      </div>
    </div>
  </div>
</section>