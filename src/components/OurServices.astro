---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import { useTranslation } from '../i18n/ui';

interface Props {
    lang: 'en' | 'es' | 'fr' | 'jp';
}

const { lang } = Astro.props;
const t = useTranslation(lang);
const Allprojects = await getCollection('projects');

const project = Allprojects.filter( project => project.id.startsWith(`${lang}/`) );

const getProjectUrl = (id: string) => {
    const cleanSlug = id.split('/')[1];
    if(lang === 'en'){
        return `/projects/${cleanSlug}`;
    }else{
        return `/${lang}/projects/${cleanSlug}`;
    }
}

---

<section class="py-24 px-6 bg-vanter-bg">
  <div class="max-w-6xl mx-auto">
    <h2 class="text-4xl font-bold text-white mb-12 font-vanter-code">{t('h2.Tittle.Services')}</h2>
    
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      {project.map((project) => (
        <div class="group bg-[#0a0a0a] border border-white/10 rounded-3xl overflow-hidden hover:border-blue-500/50 transition-all duration-500">
          <Image src={project.data.mainImage} alt={project.data.title} class="w-full h-64 object-cover" />
          
          <div class="p-8">
            <span class="text-blue-400 text-xs font-bold uppercase tracking-widest">{project.data.category}</span>
            <h3 class="text-2xl font-bold text-white mt-2 mb-4">{project.data.title}</h3>
            
            <div class="flex flex-wrap gap-2 mb-6">
              {project.data.technologies.map((tech) => (
                <span class="px-3 py-1 bg-white/5 border border-white/10 rounded-full text-[10px] text-gray-400 font-vanter-code">
                  {tech}
                </span>
              ))}
            </div>

            <a href={getProjectUrl(project.id)} class="text-white font-bold flex items-center gap-2 hover:gap-4 transition-all">
              {t('a.subtittle.Services')} <span>→</span>
            </a>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>