---
import '../styles/global.css';
import Typerwriter from '../components/typewriter.astro';
import { useTranslation } from '../i18n/ui';

interface Props {
    lang: 'en' | 'es' | 'fr' | 'jp';
}

const { lang } = Astro.props;
const t = useTranslation(lang);

---


<main class="w-full pt-32">
  
  <div class="flex flex-col items-center w-full px-4 relative"> 
      <div class="relative max-w-5xl w-full text-center"> 
          
          <h1 class="invisible text-5xl md:text-7xl lg:text-[6rem] leading-tight font-bold pointer-events-none text-center">
              {t('hero.mainTitle')}
          </h1>

          <div class="absolute inset-0 w-full h-full flex justify-center">
              <h1 class="text-5xl md:text-7xl lg:text-[6rem] leading-tight text-vanter-primary-text font-bold text-center">
                  <Typerwriter text={t('hero.mainTitle')} typingSpeed={80} />
              </h1>
          </div>

    </div>
  </div>

<div class="text-center gap-3 mt-10 flex justify-center px-4">
    <button class="bg-vanter-bg text-vanter-primary-text font-bold h-15 w-55 py-2 px-4 rounded border-2 border-vanter cursor-pointer hover:bg-vanter-primary-text hover:text-vanter-bg transition-colors">
        {t('btn.diveIntoIt')}
    </button>
    <button class="bg-vanter-bg text-vanter-primary-text font-bold h-15 w-55 py-2 px-4 rounded border-2 border-vanter cursor-pointer hover:bg-vanter-primary-text hover:text-vanter-bg transition-colors">
        {t('btn.getStarted')}
    </button>
</div>
</div> 

<section class="bg-[#050505] text-white py-24 px-6 font-sans">
  <div class="max-w-6xl mx-auto">
    
    <h2 class="text-4xl md:text-5xl lg:text-6xl font-bold mb-12 tracking-tight leading-tight">
      {t('title.h2')}<br> {t('title.FCard.h2.v2')}
    </h2>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">

      <div class="bg-[#0a0a0a] border border-white/10 rounded-3xl p-8 lg:p-10 flex flex-col h-full hover:border-white/20 transition-colors">
        
        <div class="mb-10">
          <h3 class="text-xl font-semibold mb-2">{t('title.FCard.h3')}</h3>
          <p class="text-gray-400 text-sm mb-4 max-w-sm">
            {t('p.FCard.desciption:')}
          </p>
          <a href="#" class="text-sm text-gray-300 hover:text-white flex items-center gap-1 transition-colors">
            {t('a.FCard.link')} <span class="text-xs">›</span>
          </a>
        </div>

        <div class="bg-[#020202] border border-white/10 rounded-2xl flex-1 flex flex-col mt-auto relative overflow-hidden shadow-2xl">
          
          <div class="bg-[#111] px-4 py-3 flex items-center gap-2 border-b border-white/5">
            <div class="flex gap-1.5">
              <div class="w-3 h-3 rounded-full bg-red-500/80"></div>
              <div class="w-3 h-3 rounded-full bg-yellow-500/80"></div>
              <div class="w-3 h-3 rounded-full bg-green-500/80"></div>
            </div>
            <span class="ml-4 text-xs text-gray-500 font-mono tracking-wider">infrastructure.ts</span>
          </div>

          <div class="p-5 lg:p-6 overflow-x-auto text-xs sm:text-sm font-mono leading-relaxed">
            <div class="flex">
              <span class="text-gray-700 select-none pr-4 text-right w-8">1</span>
              <span class="text-pink-400">import </span> <span class="text-gray-300">&#123; VanterEngine &#125;</span> <span class="text-pink-400">&nbsp;from</span> <span class="text-emerald-300">'@vanter/core'</span><span class="text-gray-400">;</span>
            </div>
            <div class="flex">
              <span class="text-gray-700 select-none pr-4 text-right w-8">2</span>
              <span>&nbsp;</span>
            </div>
            <div class="flex">
              <span class="text-gray-700 select-none pr-4 text-right w-8">3</span>    
              <span class="text-purple-400">export const</span> <span class="text-blue-400">&nbsp;deploySolution</span> <span class="text-purple-400">&nbsp;=&nbsp;</span> <span class="text-cyan-400">async</span> <span class="text-gray-300">(clientScope)</span> <span class="text-purple-400">=&gt;</span> <span class="text-gray-300">&#123;</span>
            </div>
            <div class="flex">
              <span class="text-gray-700 select-none pr-4 text-right w-8">4</span>
              <span class="text-gray-300">&nbsp;&nbsp;</span><span class="text-purple-400">const</span> <span class="text-gray-300">&nbsp;app</span> <span class="text-purple-400">&nbsp;=</span> <span class="text-cyan-400">&nbsp;await&nbsp;</span> <span class="text-gray-300">VanterEngine.</span><span class="text-blue-300">build</span><span class="text-gray-300">(&#123;</span>
            </div>
            <div class="flex">
              <span class="text-gray-700 select-none pr-4 text-right w-8">5</span>
              <span class="text-gray-300">&nbsp;&nbsp;&nbsp;&nbsp;performance:</span> <span class="text-emerald-300">'maximum'</span><span class="text-gray-400">,</span>
            </div>
            <div class="flex">
              <span class="text-gray-700 select-none pr-4 text-right w-8">6</span>
              <span class="text-gray-300">&nbsp;&nbsp;&nbsp;&nbsp;securityLevel:</span> <span class="text-emerald-300">'enterprise'</span><span class="text-gray-400">,</span>
            </div>
            <div class="flex">
              <span class="text-gray-700 select-none pr-4 text-right w-8">7</span>
              <span class="text-gray-300">&nbsp;&nbsp;&nbsp;&nbsp;autoScale:</span> <span class="text-orange-400">true</span><span class="text-gray-400">,</span>
            </div>
            <div class="flex">
              <span class="text-gray-700 select-none pr-4 text-right w-8">8</span>
              <span class="text-gray-300">&nbsp;&nbsp;&nbsp;&nbsp;stack: [</span><span class="text-emerald-300">'React'</span><span class="text-gray-300">, </span><span class="text-emerald-300">'Spring Boot'</span><span class="text-gray-300">, </span><span class="text-emerald-300">'Google Cloud'</span><span class="text-gray-300">]</span>
            </div>
            <div class="flex">
              <span class="text-gray-700 select-none pr-4 text-right w-8">9</span>
              <span class="text-gray-300">&nbsp;&nbsp;&#125;);</span>
            </div>
            <div class="flex">
              <span class="text-gray-700 select-none pr-4 text-right w-8">10</span>
              <span>&nbsp;</span>
            </div>
            <div class="flex">
              <span class="text-gray-700 select-none pr-4 text-right w-8">11</span>
              <span class="text-gray-300">&nbsp;&nbsp;</span><span class="text-pink-400">return&nbsp;</span> <span class="text-gray-300">app.</span><span class="text-blue-300">launch</span><span class="text-gray-300">();</span>
            </div>
            <div class="flex">
              <span class="text-gray-700 select-none pr-4 text-right w-8">12</span>
              <span class="text-gray-300">&#125;;</span>
            </div>
          </div>
        </div>

      </div>

      <div class="flex flex-col gap-6">

        <div class="bg-[#0a0a0a] border border-white/10 rounded-3xl p-8 lg:p-10 hover:border-white/20 transition-colors relative overflow-hidden h-full flex flex-col">
          
          <div class="mb-8 relative z-10">
            <h3 class="text-xl font-semibold mb-2">{t('title.SCard.h2.v2')}</h3>
            <p class="text-gray-400 text-sm mb-4 max-w-sm">
              {t('p.SCard.desciption:')}
            </p>
            <a href="#" class="text-sm text-gray-300 hover:text-white flex items-center gap-1 transition-colors">
              {t('a.SCard.link')} <span class="text-xs">›</span>
            </a>
          </div>

          <div class="bg-[#111] border border-white/10 rounded-xl p-4 flex-1 translate-y-4 translate-x-4 w-[110%] shadow-2xl relative z-0">
            <div class="flex gap-2 mb-4 border-b border-white/10 pb-4">
              <div class="w-16 h-6 bg-white/10 rounded"></div>
              <div class="w-6 h-6 bg-white/10 rounded"></div>
              <div class="w-6 h-6 bg-white/10 rounded"></div>
            </div>
            <div class="flex gap-4">
              <div class="w-1/3">
                <div class="w-full h-4 bg-white/10 rounded mb-2"></div>
                <div class="w-3/4 h-4 bg-white/5 rounded mb-2"></div>
                <div class="w-5/6 h-4 bg-white/5 rounded"></div>
              </div>
              <div class="w-2/3 bg-black rounded-lg border border-white/5 p-4">
                 <div class="w-24 h-4 bg-blue-500/20 text-blue-400 text-[10px] flex items-center justify-center rounded mb-4">Desktop • 1200</div>
                 <h5 class="text-white text-lg font-bold mb-2">Vanter App</h5>
                 <div class="w-1/2 h-2 bg-gray-700 rounded mb-1"></div>
                 <div class="w-1/3 h-2 bg-gray-700 rounded"></div>
              </div>
            </div>
          </div>

        </div>

        <div class="bg-[#0a0a0a] border border-white/10 rounded-3xl p-8 lg:p-10 hover:border-white/20 transition-colors flex flex-col">
          
          <div class="mb-8">
            <h3 class="text-xl font-semibold mb-2">{t('title.TCard.h2.v2')}</h3>
            <p class="text-gray-400 text-sm mb-4 max-w-sm">
              {t('p.TCard.desciption:')}
            </p>
            <a href="#" class="text-sm text-gray-300 hover:text-white flex items-center gap-1 transition-colors">
              {t('a.TCard.link')} <span class="text-xs">›</span>
            </a>
          </div>

          <div class="bg-black border border-white/10 rounded-2xl p-6 mt-auto">
            <p class="text-xs font-bold text-center mb-6 flex items-center justify-center gap-2">
              <span class="w-3 h-3 bg-white rounded-full text-[8px] text-black flex items-center justify-center">G</span> 
              {t('span.TCard.subtitle')}
            </p>
            
            <div class="flex justify-center gap-4 sm:gap-8">
              <div class="flex flex-col items-center">
                <div class="w-16 h-16 sm:w-20 sm:h-20 rounded-full border-[3px] border-blue-500/30 flex items-center justify-center relative">
                  <div class="absolute inset-0 rounded-full border-[3px] border-blue-500" style="clip-path: polygon(0 0, 100% 0, 100% 100%, 0 100%);"></div>
                  <span class="text-lg sm:text-2xl font-bold">99</span>
                </div>
                <span class="text-[10px] sm:text-xs text-gray-500 mt-3 font-medium">{t('span.TCard.text')}</span>
              </div>

              <div class="flex flex-col items-center">
                <div class="w-16 h-16 sm:w-20 sm:h-20 rounded-full border-[3px] border-blue-500 flex items-center justify-center shadow-[0_0_15px_rgba(59,130,246,0.5)]">
                  <span class="text-lg sm:text-2xl font-bold">100</span>
                </div>
                <span class="text-[10px] sm:text-xs text-gray-500 mt-3 font-medium">{t('span.TCard.text2')}</span>
              </div>

              <div class="flex flex-col items-center">
                <div class="w-16 h-16 sm:w-20 sm:h-20 rounded-full border-[3px] border-blue-500/30 flex items-center justify-center relative">
                  <div class="absolute inset-0 rounded-full border-[3px] border-blue-500" style="clip-path: polygon(0 0, 100% 0, 100% 90%, 0 90%);"></div>
                  <span class="text-lg sm:text-2xl font-bold">98</span>
                </div>
                <span class="text-[10px] sm:text-xs text-gray-500 mt-3 font-medium">{t('span.TCard.text3')}</span>
              </div>
            </div>
          </div>

        </div>

      </div>

    </div>
  </div>
</section>
<section class="bg-[#050505] py-24 px-6 border-t border-white/5">
  <div class="max-w-6xl mx-auto">
    
    <div class="text-center mb-16">
      <h2 class="text-vanter-primary-text font-semibold uppercase text-sm tracking-widest mb-3">{t('h2.Stack.tittle')}</h2>
      <h3 class="text-3xl md:text-5xl font-bold text-white mb-6">{t('h3.Stack.tittle')}</h3>
      <p class="text-gray-400 max-w-2xl mx-auto">
        {t('p.Stack.description')}
      </p>
    </div>

    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6">
      
      <div class="group bg-[#0a0a0a] border border-white/10 p-8 rounded-2xl flex flex-col items-center justify-center transition-all duration-300 hover:border-[#ED8B00]/50 hover:shadow-[0_0_20px_rgba(237,139,0,0.15)]">
        <img src="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/java/java-original.svg" alt="Java" class="w-12 h-12 mb-4 group-hover:scale-110 transition-transform" />
        <span class="text-white font-medium">Java</span>
        <span class="text-[10px] text-gray-500 uppercase mt-1">Backend</span>
      </div>

      <div class="group bg-[#0a0a0a] border border-white/10 p-8 rounded-2xl flex flex-col items-center justify-center transition-all duration-300 hover:border-[#00ADD8]/50 hover:shadow-[0_0_20px_rgba(0,173,216,0.15)]">
        <img src="https://cdn.simpleicons.org/go/00ADD8" alt="Go" class="w-12 h-12 mb-4 group-hover:scale-110 transition-transform" />
        <span class="text-white font-medium">Go</span>
        <span class="text-[10px] text-gray-500 uppercase mt-1">High Performance</span>
      </div>

      <div class="group bg-[#0a0a0a] border border-white/10 p-8 rounded-2xl flex flex-col items-center justify-center transition-all duration-300 hover:border-[#336791]/50 hover:shadow-[0_0_20px_rgba(51,103,145,0.15)]">
        <img src="https://cdn.simpleicons.org/postgresql/336791" alt="PostgreSQL" class="w-12 h-12 mb-4 group-hover:scale-110 transition-transform" />
        <span class="text-white font-medium">PostgreSQL</span>
        <span class="text-[10px] text-gray-500 uppercase mt-1">Relational DB</span>
      </div>

      <div class="group bg-[#0a0a0a] border border-white/10 p-8 rounded-2xl flex flex-col items-center justify-center transition-all duration-300 hover:border-[#47A248]/50 hover:shadow-[0_0_20px_rgba(71,162,72,0.15)]">
        <img src="https://cdn.simpleicons.org/mongodb/47A248" alt="MongoDB" class="w-12 h-12 mb-4 group-hover:scale-110 transition-transform" />
        <span class="text-white font-medium">MongoDB</span>
        <span class="text-[10px] text-gray-500 uppercase mt-1">NoSQL DB</span>
      </div>

      <div class="group bg-[#0a0a0a] border border-white/10 p-8 rounded-2xl flex flex-col items-center justify-center transition-all duration-300 hover:border-[#3178C6]/50 hover:shadow-[0_0_20px_rgba(49,120,198,0.15)]">
        <img src="https://cdn.simpleicons.org/typescript/3178C6" alt="TypeScript" class="w-12 h-12 mb-4 group-hover:scale-110 transition-transform" />
        <span class="text-white font-medium">TypeScript</span>
        <span class="text-[10px] text-gray-500 uppercase mt-1">Type Safety</span>
      </div>

      <div class="group bg-[#0a0a0a] border border-white/10 p-8 rounded-2xl flex flex-col items-center justify-center transition-all duration-300 hover:border-[#61DAFB]/50 hover:shadow-[0_0_20px_rgba(97,218,251,0.15)]">
        <img src="https://cdn.simpleicons.org/react/61DAFB" alt="React" class="w-12 h-12 mb-4 group-hover:scale-110 transition-transform" />
        <span class="text-white font-medium">React / Astro</span>
        <span class="text-[10px] text-gray-500 uppercase mt-1">Frontend UI</span>
      </div>

      <div class="group bg-[#0a0a0a] border border-white/10 p-8 rounded-2xl flex flex-col items-center justify-center transition-all duration-300 hover:border-[#DD0031]/50 hover:shadow-[0_0_20px_rgba(221,0,49,0.15)]">
        <img src="https://cdn.simpleicons.org/angular/DD0031" alt="Angular" class="w-12 h-12 mb-4 group-hover:scale-110 transition-transform" />
        <span class="text-white font-medium">Angular</span>
        <span class="text-[10px] text-gray-500 uppercase mt-1">Frontend Framework</span>
      </div>

      <div class="group bg-[#0a0a0a] border border-white/10 p-8 rounded-2xl flex flex-col items-center justify-center transition-all duration-300 hover:border-white/50 hover:shadow-[0_0_20px_rgba(255,255,255,0.15)]">
        <img src="https://cdn.simpleicons.org/apachekafka/white" alt="Kafka" class="w-12 h-12 mb-4 group-hover:scale-110 transition-transform" />
        <span class="text-white font-medium">Apache Kafka</span>
        <span class="text-[10px] text-gray-500 uppercase mt-1">Event Streaming</span>
      </div>

      <div class="group bg-[#0a0a0a] border border-white/10 p-8 rounded-2xl flex flex-col items-center justify-center transition-all duration-300 hover:border-[#2496ED]/50 hover:shadow-[0_0_20px_rgba(36,150,237,0.15)]">
        <img src="https://cdn.simpleicons.org/docker/2496ED" alt="Docker" class="w-12 h-12 mb-4 group-hover:scale-110 transition-transform" />
        <span class="text-white font-medium">Docker</span>
        <span class="text-[10px] text-gray-500 uppercase mt-1">Containers</span>
      </div>

      <div class="group bg-[#0a0a0a] border border-white/10 p-8 rounded-2xl flex flex-col items-center justify-center transition-all duration-300 hover:border-[#326CE5]/50 hover:shadow-[0_0_20px_rgba(50,108,229,0.15)]">
        <img src="https://cdn.simpleicons.org/kubernetes/326CE5" alt="Kubernetes" class="w-12 h-12 mb-4 group-hover:scale-110 transition-transform" />
        <span class="text-white font-medium">Kubernetes</span>
        <span class="text-[10px] text-gray-500 uppercase mt-1">Orchestration</span>
      </div>

      <div class="group bg-[#0a0a0a] border border-white/10 p-8 rounded-2xl flex flex-col items-center justify-center transition-all duration-300 hover:border-[#4285F4]/50 hover:shadow-[0_0_20px_rgba(66,133,244,0.15)]">
        <img src="https://cdn.simpleicons.org/googlecloud/4285F4" alt="GCP" class="w-12 h-12 mb-4 group-hover:scale-110 transition-transform" />
        <span class="text-white font-medium">Google Cloud</span>
        <span class="text-[10px] text-gray-500 uppercase mt-1">Cloud Infrastructure</span>
      </div>

      <div class="group bg-[#0a0a0a] border border-white/10 p-8 rounded-2xl flex flex-col items-center justify-center transition-all duration-300 hover:border-[#FF9900]/50 hover:shadow-[0_0_20px_rgba(255,153,0,0.15)]">
        <img src="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/amazonwebservices/amazonwebservices-original-wordmark.svg" alt="AWS" class="w-16 h-16 mb-4 group-hover:scale-110 transition-transform" />
        <span class="text-white font-medium">AWS</span>
        <span class="text-[10px] text-gray-500 uppercase mt-1">Cloud Services</span>
      </div>

    </div>
  </div>
</section>

<section class="relative py-24 px-6 overflow-hidden">
  
  <div class="absolute inset-0 z-0 flex items-center justify-center pointer-events-none">
    <div class="w-150 h-75 bg-linear-to-r from-blue-600/20 to-purple-600/20 blur-[120px] rounded-full"></div>
  </div>

  <div class="relative z-10 max-w-4xl mx-auto text-center bg-[#0a0a0a]/50 backdrop-blur-xl border border-white/10 p-10 md:p-16 rounded-3xl shadow-2xl">
    
    <h2 class="text-3xl md:text-5xl font-bold text-white mb-6 tracking-tight">
      {t('h2.Work.title')}
    </h2>
    
    <p class="text-gray-400 text-base md:text-lg mb-10 max-w-2xl mx-auto leading-relaxed">
      {t('p.Work.description')}
    </p>
    
    <div class="flex flex-col sm:flex-row justify-center items-center gap-4">
      
      <a href="/portfolio" class="w-full sm:w-auto bg-white text-black font-bold py-3 px-8 rounded-xl hover:bg-gray-200 hover:scale-105 transition-all duration-300 shadow-[0_0_20px_rgba(255,255,255,0.2)]">
        {t('btn.viewWork')}
      </a>
      
      <a href="/contact" class="w-full sm:w-auto bg-transparent text-white font-bold py-3 px-8 rounded-xl border border-white/20 hover:bg-white/10 hover:border-white/40 transition-all duration-300">
        {t('btn.contactUs')}
      </a>
      
    </div>
  </div>
</section>



<script>
    import '../js/main.js';
</script>