---
import '../styles/global.css';
import Typerwriter from '../components/typewriter.astro';

const mainTitle = "Building high-performance software and digital infrastructure.";
---

<div class="w-full h-15 flex items-center justify-between border-b-2 border-gray-800 p-4">
    <div class="flex items-center gap-4 ">
        <img class="rounded-lg size-10" 
        src="/vanter-tech_logo.webp" alt="Vanter Tech Logo">
        <h2 class="font-code text-2xl font-semibold text-white">VANTER</h2>
    </div>
    <div>
        <ul class="flex gap-6">
            <li><a href="/about" class="text-white hover:text-blue-500">ABOUT US</a></li>
            <li><a href="/services" class="text-white hover:text-blue-500">SERVICES</a></li>
            <li><a href="/contact" class="text-white hover:text-blue-500">CONTACT US</a></li>
        </ul>
    </div>
</div>
<div class="mt-12">
    <p class="text-5xl md:text-7xl lg:text-[6rem] leading-tight text-white font-bold max-w-5xl" >
        <Typerwriter text={mainTitle} typingSpeed={80} />
    </p>
</div>
<div class="text-center gap-3 mt-10 flex justify-center">
    <button class="bg-black text-white font-bold h-15 w-55 py-2 px-4 rounded border-2 border-gray-800 cursor-pointer">
        Get Started
    </button>
    <button class="bg-black text-white font-bold h-15 w-55 py-2 px-4 rounded border-2 border-gray-800 cursor-pointer">
        Get Started
    </button>
</div>