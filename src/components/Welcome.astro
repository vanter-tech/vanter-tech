---
import '../styles/global.css';
import Typerwriter from '../components/typewriter.astro';
import { useTranslation } from '../i18n/ui';

interface Props {
    lang: 'en' | 'es' | 'fr' | 'jp';
}

const { lang } = Astro.props;

const t = useTranslation(lang);
---

<nav class="relative w-full min-h-15 flex items-center justify-between border-b-2 border-vanter-border p-4">
  
  <div class="flex items-center gap-4 z-20">
    <img class="rounded-lg size-10" src="/vanter-tech_logo.webp" alt="Vanter Tech Logo">
    <h2 class="text-2xl font-semibold text-vanter-primary-text font-code">VANTER</h2>
  </div>

  <button id="burger-btn" class="md:hidden flex flex-col gap-1.5 p-2 cursor-pointer z-20">
    <div id="line1" class="w-6 h-0.5 bg-vanter-primary-text transition-all duration-300"></div>
    <div id="line2" class="w-6 h-0.5 bg-vanter-primary-text transition-all duration-300"></div>
  </button>

  <div id="mobile-menu" class="absolute top-full left-0 w-full bg-vanter-bg border-b-2 border-vanter-border p-6 flex flex-col gap-8 z-10 transition-all duration-600 ease-in-out opacity-0 pointer-events-none md:static md:flex-row md:items-center md:justify-end md:w-auto md:border-none md:p-0 md:opacity-100 md:pointer-events-auto">
    
    <ul class="flex flex-col md:flex-row gap-6 text-center md:text-left">
      <li class="menu-item opacity-0 translate-y-4 transition-all duration-300 md:opacity-100 md:translate-y-0">
        <a href="/about" class="text-vanter-primary-text hover:text-blue-500">{t('nav.about')}</a>
      </li>
      <li class="menu-item opacity-0 translate-y-4 transition-all duration-300 md:opacity-100 md:translate-y-0">
        <a href="/services" class="text-vanter-primary-text hover:text-blue-500">{t('nav.services')}</a>
      </li>
      <li class="menu-item opacity-0 translate-y-4 transition-all duration-300 md:opacity-100 md:translate-y-0">
        <a href="/contact" class="text-vanter-primary-text hover:text-blue-500">{t('nav.contact')}</a>
      </li>
    </ul>

    <div class="flex flex-col md:flex-row gap-4 mt-4 md:mt-0">
      <button class="menu-item opacity-0 translate-y-4 transition-all duration-300 md:opacity-100 md:translate-y-0 bg-vanter-bg text-vanter-primary-text font-bold py-2 px-4 rounded border-2 border-vanter-border cursor-pointer w-full md:w-auto">
        {t('btn.pricing')}
      </button>
      <button class="menu-item opacity-0 translate-y-4 transition-all duration-300 md:opacity-100 md:translate-y-0 bg-vanter-bg text-vanter-primary-text font-bold py-2 px-4 rounded border-2 border-vanter-border cursor-pointer w-full md:w-auto">
        {t('btn.more')}
      </button>
    </div>

</div>
</nav>
<div class="mt-12 flex flex-col items-center"> 
    
    <div class="relative max-w-5xl">
    
        <h1 class="invisible text-5xl md:text-7xl lg:text-[6rem] leading-tight font-bold pointer-events-none">
           {t('hero.mainTitle')}
        </h1>

        <div class="absolute inset-0 w-full h-full">
            <h1 class="text-5xl md:text-7xl lg:text-[6rem] leading-tight text-vanter-primary-text font-bold">
                <Typerwriter text={t('hero.mainTitle')} typingSpeed={80} />
            </h1>
    </div>

  </div>
</div>
<div class="text-center gap-3 mt-10 flex justify-center">
    <button class="bg-vanter-bg text-vanter-primary-text font-bold h-15 w-55 py-2 px-4 rounded border-2
     border-vanter cursor-pointer">
        {t('btn.diveIntoIt')}
    </button>
    <button class="bg-vanter-bg text-vanter-primary-text font-bold h-15 w-55 py-2 px-4 rounded border-2
     border-vanter cursor-pointer">
        {t('btn.getStarted')}
    </button>
</div>
<script>
    import '../js/main.js';
</script>