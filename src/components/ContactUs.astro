---
// import { useTranslation } from '../i18n/ui';

interface Props {
  lang: 'en' | 'es' | 'fr' | 'jp';
}

const { lang } = Astro.props;
// const t = useTranslation(lang);
---

<section class="pt-32 pb-24 px-6 bg-vanter-bg text-white relative overflow-hidden" id="contact">
  
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-150 h-150 bg-blue-600/10 rounded-full blur-[120px] pointer-events-none"></div>

  <div class="max-w-7xl mx-auto relative z-10">
    
    <div class="text-center mb-16 md:mb-20">
      <span class="text-blue-400 text-sm font-bold uppercase tracking-widest mb-3 block">Conecta con nosotros</span>
      <h2 class="text-4xl md:text-5xl lg:text-6xl font-bold font-vanter-code mb-4">
        Inicia tu <span class="text-transparent bg-clip-text bg-linear-to-r from-blue-400 to-purple-500">Sistema</span>
      </h2>
      <p class="text-gray-400 text-lg max-w-2xl mx-auto">
        Envíanos tus requerimientos y nuestro equipo ejecutará el código necesario para llevar tu proyecto al siguiente nivel.
      </p>
    </div>

    <div id="contact-grid" class="grid grid-cols-1 md:grid-cols-2 gap-8 lg:gap-12 items-stretch transition-all duration-500 ease-in-out max-w-5xl mx-auto">
      
      <div id="terminal-wrapper" class="w-full h-full transition-all duration-300 transform origin-left">
        <div class="bg-[#050505]/80 backdrop-blur-sm border border-white/10 hover:border-blue-500/30 transition-colors duration-500 rounded-2xl overflow-hidden shadow-2xl relative font-vanter-code text-sm md:text-base h-full flex flex-col group">
          
          <div class="bg-[#111] border-b border-white/5 px-4 py-3 flex items-center relative shrink-0">
            <div class="flex gap-2 absolute left-4">
              <button id="btn-close" aria-label="Cerrar Terminal" class="w-3 h-3 rounded-full bg-red-500/80 hover:bg-red-400 hover:shadow-[0_0_8px_rgba(239,68,68,0.8)] transition-all cursor-pointer"></button>
              <button id="btn-minimize" aria-label="Minimizar Terminal" class="w-3 h-3 rounded-full bg-yellow-500/80 hover:bg-yellow-400 hover:shadow-[0_0_8px_rgba(234,179,8,0.8)] transition-all cursor-pointer"></button>
              <div class="w-3 h-3 rounded-full bg-green-500/80"></div>
            </div>
            <div class="w-full text-center text-gray-500 text-xs tracking-widest uppercase select-none">
              guest@vanter-tech:~
            </div>
          </div>

          <div class="p-6 md:p-8 space-y-5 text-gray-300 grow flex flex-col justify-center">
            <pre class="text-blue-500 font-bold leading-tight mb-2 text-[10px] sm:text-xs lg:text-sm select-none group-hover:text-blue-400 transition-colors">
__   __ _    _  _ _____ ___ ___ 
\ \ / // \  | \| |_   _| __| _ \
 \ V // _ \ | .` | | | | _||   /
  \_//_/ \_\|_|\_| |_| |___|_|_\
            </pre>
            <div class="text-gray-500 text-xs mb-6 border-b border-white/10 pb-4 flex justify-between">
              <span>v1.0.0 - Contact Module Initialized</span>
              <span class="text-green-500/70">Sys: Online</span>
            </div>
            
            <div><span class="text-blue-400 font-bold">guest@vanter</span><span class="text-gray-500">:</span><span class="text-purple-400">~</span>$ ./connect.sh</div>
            
            <div class="text-gray-500 animate-pulse space-y-1 pl-2 border-l-2 border-gray-800">
              <p>Estableciendo protocolo seguro... <span class="text-green-400">OK</span></p>
              <p>Desplegando canal de comunicación... <span class="text-green-400">OK</span></p>
            </div>

            <div class="pt-2"><span class="text-blue-400 font-bold">guest@vanter</span><span class="text-gray-500">:</span><span class="text-purple-400">~</span>$ cat status.json</div>
            
            <div class="text-gray-300">
              <span class="text-yellow-300">&#123;</span>
              <div class="pl-6 space-y-1 my-1">
                <p><span class="text-blue-300">"status"</span><span class="text-gray-500">:</span> <span class="text-green-400">"available_for_hire"</span>,</p>
                <p><span class="text-blue-300">"email"</span><span class="text-gray-500">:</span> <span class="text-green-400">"hello@vanter.tech"</span></p>
              </div>
              <span class="text-yellow-300">&#125;</span>
            </div>

            <div class="flex items-center pt-4 mt-auto">
              <span class="text-blue-400 font-bold">guest@vanter</span><span class="text-gray-500">:</span><span class="text-purple-400">~</span>$ 
              <span class="w-2.5 h-5 bg-gray-400 ml-2 animate-ping" style="animation-duration: 1.5s;"></span>
            </div>
          </div>
        </div>
      </div>

      <div class="w-full h-full transition-all duration-500">
        <div class="bg-[#0a0a0a]/80 backdrop-blur-sm border border-white/10 hover:border-white/20 transition-colors duration-500 p-8 md:p-10 rounded-3xl shadow-2xl relative h-full flex flex-col justify-center">
          <form action="https://api.web3forms.com/submit" method="POST" class="flex flex-col gap-8">
            <input type="hidden" name="access_key" value="TU_API_KEY_AQUI">
            
            <div class="flex flex-col gap-2 group">
              <label for="name" class="text-sm font-vanter-code text-gray-400 group-focus-within:text-blue-400 transition-colors">Nombre Completo</label>
              <input type="text" id="name" name="name" required class="w-full bg-transparent border-b border-white/20 px-0 py-3 text-white focus:outline-none focus:border-blue-400 focus:bg-white/5 transition-all placeholder:text-gray-600 rounded-t-md" placeholder="Ej. Juan Pérez" />
            </div>

            <div class="flex flex-col gap-2 group">
              <label for="email" class="text-sm font-vanter-code text-gray-400 group-focus-within:text-blue-400 transition-colors">Correo Electrónico</label>
              <input type="email" id="email" name="email" required class="w-full bg-transparent border-b border-white/20 px-0 py-3 text-white focus:outline-none focus:border-blue-400 focus:bg-white/5 transition-all placeholder:text-gray-600 rounded-t-md" placeholder="juan@empresa.com" />
            </div>

            <div class="flex flex-col gap-2 group">
              <label for="message" class="text-sm font-vanter-code text-gray-400 group-focus-within:text-blue-400 transition-colors">Mensaje</label>
              <textarea id="message" name="message" rows="4" required class="w-full bg-transparent border-b border-white/20 px-0 py-3 text-white focus:outline-none focus:border-blue-400 focus:bg-white/5 transition-all placeholder:text-gray-600 resize-none rounded-t-md" placeholder="Cuéntanos sobre tu proyecto o idea..."></textarea>
            </div>

            <button type="submit" class="mt-4 bg-white text-black font-bold py-4 rounded-xl hover:bg-blue-400 hover:shadow-[0_0_20px_rgba(59,130,246,0.4)] hover:text-white transition-all duration-300 transform hover:-translate-y-1">
              Enviar Mensaje
            </button>
          </form>
        </div>
      </div>

    </div>
  </div>
</section>

<button 
  id="floating-terminal" 
  title="Restaurar Terminal"
  class="fixed bottom-6 right-6 w-16 h-16 bg-[#050505] border border-white/20 rounded-full shadow-[0_0_15px_rgba(59,130,246,0.2)] flex items-center justify-center text-blue-400 font-vanter-code font-bold text-xl hover:scale-110 hover:border-blue-500/50 hover:shadow-[0_0_25px_rgba(59,130,246,0.5)] transition duration-500 z-50 translate-y-24 opacity-0 pointer-events-none">
  {'>_'}
</button>

<script src="/src/js/main.ts"></script>