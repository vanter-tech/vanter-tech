---
// import { useTranslation } from '../i18n/ui';

interface Props {
  lang: 'en' | 'es' | 'fr' | 'jp';
}

const { lang } = Astro.props;
// const t = useTranslation(lang);
---

<section class="py-24 px-6 bg-vanter-bg text-white relative overflow-hidden" id="contact">
  <div class="max-w-7xl mx-auto">
    
    <div class="grid grid-cols-1 md:grid-cols-2 gap-12 lg:gap-20 items-center">
      
      <div class="w-full">
        <div class="bg-[#050505] border border-white/10 rounded-2xl overflow-hidden shadow-2xl relative font-vanter-code text-sm md:text-base xl:text-lg">
          
          <div class="bg-[#111] border-b border-white/5 px-4 py-3 flex items-center relative">
            <div class="flex gap-2 absolute left-4">
              <div class="w-3 h-3 rounded-full bg-red-500/80"></div>
              <div class="w-3 h-3 rounded-full bg-yellow-500/80"></div>
              <div class="w-3 h-3 rounded-full bg-green-500/80"></div>
            </div>
            <div class="w-full text-center text-gray-500 text-xs tracking-widest uppercase">
              guest@vanter-tech:~
            </div>
          </div>

          <div class="p-6 md:p-8 lg:p-10 space-y-4 text-gray-300 leading-relaxed">
            
            <div>
              <span class="text-blue-400 font-bold">guest@vanter</span><span class="text-gray-500">:</span><span class="text-purple-400">~</span>$ ./init_contact.sh
            </div>
            
            <div class="text-gray-500 animate-pulse space-y-1">
              <p>[+] Estableciendo conexión segura... <span class="text-green-400">OK</span></p>
              <p>[+] Cargando módulos de innovación.. <span class="text-green-400">OK</span></p>
            </div>

            <div class="pt-2">
              <span class="text-blue-400 font-bold">guest@vanter</span><span class="text-gray-500">:</span><span class="text-purple-400">~</span>$ cat contact.json
            </div>
            
            <div class="text-gray-300">
              <span class="text-yellow-300">&#123;</span>
              <div class="pl-6 space-y-1 my-1">
                <p><span class="text-blue-300">"status"</span><span class="text-gray-500">:</span> <span class="text-green-400">"available_for_hire"</span>,</p>
                <p><span class="text-blue-300">"email"</span><span class="text-gray-500">:</span> <span class="text-green-400">"hello@vanter.tech"</span>,</p>
                <p><span class="text-blue-300">"response_time"</span><span class="text-gray-500">:</span> <span class="text-green-400">"< 24_hours"</span></p>
              </div>
              <span class="text-yellow-300">&#125;</span>
            </div>

            <div class="flex items-center pt-2">
              <span class="text-blue-400 font-bold">guest@vanter</span><span class="text-gray-500">:</span><span class="text-purple-400">~</span>$ 
              <span class="w-2.5 h-5 bg-gray-400 ml-2 animate-ping" style="animation-duration: 1.5s;"></span>
            </div>

          </div>
        </div>
      </div>

      <div class="w-full">
        <div class="bg-[#0a0a0a] border border-white/10 p-8 md:p-10 rounded-3xl shadow-2xl relative">
          <form action="https://api.web3forms.com/submit" method="POST" class="flex flex-col gap-6">
            <input type="hidden" name="access_key" value="TU_API_KEY_AQUI">
            
            <div class="flex flex-col gap-2">
              <label for="name" class="text-sm font-vanter-code text-gray-400">Nombre Completo</label>
              <input type="text" id="name" name="name" required class="w-full bg-transparent border-b border-white/20 px-0 py-3 text-white focus:outline-none focus:border-blue-400 transition-colors placeholder:text-gray-600" placeholder="Ej. Juan Pérez" />
            </div>

            <div class="flex flex-col gap-2">
              <label for="email" class="text-sm font-vanter-code text-gray-400">Correo Electrónico</label>
              <input type="email" id="email" name="email" required class="w-full bg-transparent border-b border-white/20 px-0 py-3 text-white focus:outline-none focus:border-blue-400 transition-colors placeholder:text-gray-600" placeholder="juan@empresa.com" />
            </div>

            <div class="flex flex-col gap-2">
              <label for="message" class="text-sm font-vanter-code text-gray-400">Mensaje</label>
              <textarea id="message" name="message" rows="4" required class="w-full bg-transparent border-b border-white/20 px-0 py-3 text-white focus:outline-none focus:border-blue-400 transition-colors placeholder:text-gray-600 resize-none" placeholder="Cuéntanos sobre tu proyecto o idea..."></textarea>
            </div>

            <button type="submit" class="mt-4 bg-white text-black font-bold py-4 rounded-xl hover:bg-blue-400 hover:text-white transition-all duration-300 transform hover:-translate-y-1">
              Enviar Mensaje
            </button>
          </form>
        </div>
      </div>

    </div>
  </div>
</section>