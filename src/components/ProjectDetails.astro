---
import { useTranslation } from '../i18n/ui';

interface Props {
  project: any;
  lang: 'en' | 'es' | 'fr' | 'jp';
}

const { project, lang } = Astro.props;
const t = useTranslation(lang);

const backUrl = lang === 'en' ? '/services' : `/${lang}/services`;
---

<main class="w-full pt-32 px-6 bg-vanter-bg text-white">
  <div class="max-w-4xl mx-auto">
    
    <a href={backUrl} class="text-gray-400 hover:text-white mb-8 inline-block transition-colors font-vanter-code">
      {t('a.subtittle.ProjectDetail')}
    </a>

    <div class="mb-12">
      <span class="text-blue-400 text-sm font-bold uppercase tracking-widest">{project.data.category}</span>
      <h1 class="text-5xl md:text-7xl font-bold mt-2 mb-6">{project.data.title}</h1>
      <p class="text-xl text-gray-400 leading-relaxed text-pretty">{project.data.description}</p>
    </div>

    <div class="relative rounded-3xl overflow-hidden border border-white/10 mb-16 shadow-2xl group" data-carousel>
      
      <div class="flex transition-transform duration-500 ease-in-out" data-track>
        {project.data.gallery.map((img: any, index: number) => (
          <div class="min-w-full relative" data-index={index}>
            <img src={img.url} alt={img.alt} class="w-full h-auto object-cover aspect-video" />
            
            <div class="absolute bottom-10 left-0 w-full text-center pointer-events-none">
              <span class="bg-black/60 backdrop-blur-md px-4 py-2 rounded-lg text-sm text-gray-200 inline-block">
                {img.description}
              </span>
            </div>
          </div>
        ))}
      </div>

      <button 
        class="absolute z-10 top-1/2 left-4 -translate-y-1/2 bg-black/50 hover:bg-black/80 text-white w-10 h-10 flex items-center justify-center rounded-full opacity-0 group-hover:opacity-100 transition-opacity backdrop-blur-sm" 
        data-prev>
        ←
      </button>
      <button 
        class="absolute z-10 top-1/2 right-4 -translate-y-1/2 bg-black/50 hover:bg-black/80 text-white w-10 h-10 flex items-center justify-center rounded-full opacity-0 group-hover:opacity-100 transition-opacity backdrop-blur-sm" 
        data-next>
        →
      </button>

      <div class="absolute z-10 bottom-4 left-1/2 -translate-x-1/2 flex gap-2">
        {project.data.gallery.map((_: any, index: number) => (
          <button
            class={`w-3 h-3 rounded-full border border-white/50 transition-colors ${index === 0 ? 'bg-white' : 'bg-transparent'}`}
            data-dot={index}
            aria-label={`Ir a imagen ${index + 1}`}
          ></button>
        ))}
      </div>
    </div>
    <div class="mb-16">
      <h3 class="text-2xl font-bold mb-6 font-vanter-code">{t('h3.Tittle.ProjectDetail')}</h3>
      <div class="flex flex-wrap gap-3">
        {project.data.technologies.map((tech: string) => (
          <span class="px-4 py-2 bg-[#0a0a0a] border border-white/10 rounded-lg text-sm text-gray-300 font-vanter-code">
            {tech}
          </span>
        ))}
      </div>
    </div>

  </div>
</main>
<section class="relative py-24 px-6 overflow-hidden">
  
  <div class="absolute inset-0 z-0 flex items-center justify-center pointer-events-none">
    <div class="w-150 h-75 bg-linear-to-r from-blue-600/20 to-purple-600/20 blur-[120px] rounded-full"></div>
  </div>

  <div class="relative z-10 max-w-4xl mx-auto text-center bg-[#0a0a0a]/50 backdrop-blur-xl border border-white/10 p-10 md:p-16 rounded-3xl shadow-2xl">
    
    <h2 class="text-3xl md:text-5xl font-bold text-white mb-6 tracking-tight">
      {t('h2.tittle.section.ProjectDetail')}
    </h2>
    
    <p class="text-gray-400 text-base md:text-lg mb-10 max-w-2xl mx-auto leading-relaxed">
      {t('p.description.section.ProjectDetail')}
    </p>
    
    <div class="flex flex-col sm:flex-row justify-center items-center gap-4">
      
      <a href="/" class="w-full sm:w-auto bg-white text-black font-bold py-3 px-8 rounded-xl hover:bg-gray-200 hover:scale-105 transition-all duration-300 shadow-[0_0_20px_rgba(255,255,255,0.2)]">
        {t('a.section.ProjectDetail.viewWork')}
      </a>
      
      
    </div>
  </div>
</section>

<script src="/src/js/main.ts"></script>