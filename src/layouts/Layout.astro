---
import '../styles/global.css';
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/vanter-tech_logo.ico" />
		<link rel="icon" href="/vanter-tech_logo.ico" />
		<meta name="generator" content={Astro.generator} />

		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:ital,wght@0,100..800;1,100..800&display=swap" rel="stylesheet">
		
		<script is:inline>

			const userLang = navigator.language || navigator.userLanguage;
			const currerntPath = window.location.pathname;

			if(userLang.startsWith('es') && currerntPath === '/') {
				window.location.pathname = '/es' + currerntPath;
			}

		</script>

		<title>Vanter</title>
	</head>
	<body class="bg-vanter-bg color-vanter-primary-text font-vanter-code min-h-screen ">
		<div>
			<slot />
		</div>
	</body>
</html>

